# Base URL of the rule-based-server. The frontend never talks to the
# AI server directly — every call is routed through the rule-based-server,
# which orchestrates rules + AI under the latency budget.
#
# Local development:
#   REACT_APP_RULE_API=http://localhost:3000
#
# Production (deployed on Render):
#   REACT_APP_RULE_API=https://rule-based-server.onrender.com
REACT_APP_RULE_API=http://localhost:3000
