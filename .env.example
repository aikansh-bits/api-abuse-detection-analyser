# Base URL of the rule-based-server. The frontend routes every detection
# request through it; the rule server in turn calls the AI server.
#
# Local development:
#   REACT_APP_RULE_API=http://localhost:3000
#
# Production (deployed on Render):
#   REACT_APP_RULE_API=https://rule-based-server.onrender.com
REACT_APP_RULE_API=http://localhost:3000

# Optional direct URL for the AI server. The frontend never makes detection
# calls to it — those always route through the rule server. Setting this lets
# the dashboard send a parallel "warmup" ping on app mount, so both Render
# services cold-start simultaneously instead of one after the other.
REACT_APP_AI_API=http://localhost:8000
